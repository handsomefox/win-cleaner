#include <winver.h>

1 ICON "assets/app.ico"
1 RT_MANIFEST "app.manifest"

1 VERSIONINFO
FILEVERSION 1,0,4,0
PRODUCTVERSION 1,0,4,0
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
FILEFLAGS 0
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904B0"
    BEGIN
      VALUE "FileDescription", "Windows Cleaner\0"
      VALUE "FileVersion", "1.0.4\0"
      VALUE "InternalName", "Windows Cleaner.exe\0"
      VALUE "OriginalFilename", "Windows Cleaner.exe\0"
      VALUE "ProductName", "Windows Cleaner\0"
      VALUE "ProductVersion", "1.0.4\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
